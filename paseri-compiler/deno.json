{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "name": "@paseri/compiler",
  "license": "MIT",
  "version": "0.7.2",
  "description": "Ahead-of-time compiler for Paseri schemas.",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.19",
    "expect-type": "npm:expect-type@^1.3.0",
    "ts-blank-space": "npm:ts-blank-space@^0.9.0",
    "typescript": "npm:typescript@^6.0.3",
    "zod": "npm:zod@^4.4.3"
  },
  "tasks": {
    "generate_runtime": "deno run --allow-read --allow-write bin/generate_runtime.ts",
    "generate_fixtures": "deno run --allow-read --allow-write --allow-env bin/generate_fixtures.ts"
  },
  "test": {
    "permissions": {
      "env": true,
      "read": true
    }
  },
  "publish": {
    "include": ["src", "LICENSE.md", "README.md"],
    "exclude": [
      "src/**/*.test.ts",
      "src/_test-helpers.ts",
      "src/aot-shadow.ts",
      "src/runtime.ts",
      "src/generated-fixtures"
    ]
  }
}
