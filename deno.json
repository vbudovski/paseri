{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "imports": {
    "@biomejs/biome": "npm:@biomejs/biome@^2.4.13",
    "@commitlint/cli": "npm:@commitlint/cli@^20.5.2",
    "@commitlint/config-conventional": "npm:@commitlint/config-conventional@^20.5.0",
    "@commitlint/types": "npm:@commitlint/types@^20.5.0",
    "husky": "npm:husky@^9.1.7",
    "lint-staged": "npm:lint-staged@^16.4.0"
  },
  "tasks": {
    "init": "deno run --allow-env --allow-read --allow-write --allow-run husky",
    "lint-staged": "deno run --allow-env --allow-read --allow-write --allow-sys --allow-run lint-staged",
    "ci": "deno run --allow-env --allow-read --allow-run @biomejs/biome ci",
    "check": "deno run --allow-env --allow-read --allow-run @biomejs/biome check",
    "commitlint": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run @commitlint/cli"
  },
  "workspace": ["paseri-lib", "paseri-docs"],
  "nodeModulesDir": "auto",
  "unstable": ["bare-node-builtins"],
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "isolatedDeclarations": true
  },
  "allowScripts": ["npm:esbuild@0.27.4", "npm:fsevents@2.3.3", "npm:sharp@0.34.5"]
}
