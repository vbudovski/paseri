{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "name": "@vbudovski/paseri",
  "license": "MIT",
  "version": "0.2.1",
  "exports": {
    ".": "./src/index.ts",
    "./locales": "./src/locales/index.ts"
  },
  "imports": {
    "@badrap/valita": "jsr:@badrap/valita@0.4.6",
    "@standard-schema/spec": "jsr:@standard-schema/spec@^1.1.0",
    "@std/expect": "jsr:@std/expect@1.0.18",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@sveltejs/acorn-typescript": "npm:@sveltejs/acorn-typescript@^1.0.9",
    "@vbudovski/rollup-plugin-transform-regex": "jsr:@vbudovski/rollup-plugin-transform-regex@^0.1.4",
    "acorn": "npm:acorn@^8.16.0",
    "expect-type": "npm:expect-type@1.3.0",
    "fast-check": "npm:fast-check@4.7.0",
    "recheck": "npm:recheck@4.5.0",
    "regex": "npm:regex@^6.1.0",
    "rollup": "npm:rollup@^4.60.1",
    "type-fest": "npm:type-fest@5.4.1",
    "zod": "npm:zod@4.3.6"
  },
  "tasks": {
    "generate_emoji": "deno run --allow-net --allow-write bin/generate_emoji.ts",
    "generate_regex": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run bin/generate_regex.ts",
    "calculate_bundle_size": "deno bundle --platform browser --minify src/index.ts | gzip | wc -c | numfmt --to=iec"
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any", "no-unused-vars"]
    }
  },
  "test": {
    "permissions": {
      "env": true,
      "read": true
    }
  },
  "publish": {
    "include": ["src", "LICENSE.md", "README.md"],
    "exclude": ["src/**/*.test.ts", "src/emoji.json"]
  }
}
