{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "license": "MIT",
  "imports": {
    "@astrojs/check": "npm:@astrojs/check@^0.9.9",
    "@astrojs/preact": "npm:@astrojs/preact@^6.0.0",
    "@astrojs/sitemap": "npm:@astrojs/sitemap@^3.7.3",
    "@astrojs/starlight": "npm:@astrojs/starlight@^0.41.0",
    "@preact/signals": "npm:@preact/signals@^2.9.2",
    "@preact/signals-core": "npm:@preact/signals-core@^1.14.3",
    "astro": "npm:astro@^7.0.3",
    "charts.css": "npm:charts.css@^1.2.0",
    "codejar": "npm:codejar@^4.3.0",
    "preact": "npm:preact@^10.29.2",
    "sugar-high": "npm:sugar-high@^1.2.1",
    "rehype-external-links": "npm:rehype-external-links@^3.0.0",
    "rollup-plugin-visualizer": "npm:rollup-plugin-visualizer@^7.0.1",
    "sharp": "npm:sharp@^0.35.2",
    "typescript": "npm:typescript@^6.0.3",
    "zod": "npm:zod@^4.4.3"
  },
  "tasks": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "exclude": [".astro", "dist", "src/env.d.ts"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "isolatedDeclarations": false,
    "exactOptionalPropertyTypes": false
  }
}
